---

{% set remove_keys = ['UID', 'CAP_EFFECTIVE', 'BOOT_ID', 'MACHINE_ID', 'RUNTIME_SCOPE', 'PRIORITY',
                      ''] %}

service:
  flush: 1
  grace: 5
  daemon: no
  dns.mode: UDP
  hot_reload: on
  log_level: info
  storage.path: /opt/fluent-bit/storage
  storage.backlog.flush_on_shutdown: on
  storage.keep.rejected: on
  storage.rejected.path: /opt/fluent-bit/dlq

pipeline:
  inputs:
    - name: systemd
      read_from_tail: yes # Don't try to process all logs prior to now
      strip_underscores: yes # Clean up key names
      systemd_filter: _SYSTEMD_UNIT=thundermail.service
      tag: systemd.thundermail
      processors:
        - name: content_modifier
          action: delete
          key: UID

  outputs:
    - name: forward
      match: systemd.*
      host: fluentbit{{ '' if env == 'prod' else f'-{env}' }}
      port: 24224
      shared-secret: {{ fluentbit_shared_secret }}
