#!/bin/bash

{#  This is a first-stage bootstrapping script which mostly serves to build an environment in which the second-stage
    bootstrapping script can run. The second stage content is contained in the base64-encoded zip file which is
    templated into place by the mailstrom Pulumi code. The bootstrapping process is documented in the readme. Because
    user data must be small, these files are intentionally not heavy on internal documentation. -#}

set -x
set -e

BOOTSTRAP_DIR=/opt/stalwart-bootstrap
BOOTSTRAP_TBZ=/root/bootstrap.tbz
STALWART_DIR=/opt/stalwart

echo '[fluent-bit]
name = Fluent Bit
baseurl = https://packages.fluentbit.io/amazonlinux/2023/
gpgcheck=1
gpgkey=https://packages.fluentbit.io/fluentbit.key
enabled=1' > /etc/yum.repos.d/fluent-bit.repo

dnf update -y
dnf install -y bzip2 docker fluent-bit python3.12

mkdir -p $STALWART_DIR/etc

python3.12 -m ensurepip
pip3.12 install virtualenv
/usr/local/bin/virtualenv -p python3.12 $BOOTSTRAP_DIR

systemctl start docker
systemctl enable docker

echo '{{ bootstrap_tbz_base64 }}' | base64 -d > $BOOTSTRAP_TBZ
tar -xvf $BOOTSTRAP_TBZ -C $BOOTSTRAP_DIR

source $BOOTSTRAP_DIR/bin/activate
pip install -r $BOOTSTRAP_DIR/requirements.txt
python $BOOTSTRAP_DIR/bootstrap.py

# Prevent default fluent-bit from running
systemctl stop fluent-bit
systemctl mask fluent-bit
rm -f /etc/fluent-bit/fluent-bit.conf

systemctl daemon-reload
systemctl enable fluent-bit-collector thundermail
systemctl start fluent-bit-collector thundermail

